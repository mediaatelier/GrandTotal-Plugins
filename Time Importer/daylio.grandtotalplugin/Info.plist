	<string>Geben Sie Ihre Office-Manager API-Zugangsdaten ein. Die API-URL, den API-Key und das API-Secret finden Sie in Ihrem Office-Manager unter Einstellungen &gt; API-Zugang.</string>
	<key>GrandTotalMinimumVersion</key>
	<real>7</real>
	<key>copyright</key>
	<string>(c) 2026 CODISH Stephan Härtl</string>
	<key>types</key>
	<array>
		<string>timeimporter</string>
	</array>
