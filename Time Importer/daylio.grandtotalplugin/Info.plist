	<string>icon.png</string>
	<key>CFBundleIdentifier</key>
	<string>com.codish.daylio</string>
	<key>CFBundleVersion</key>
	<string>1.0</string>
	<key>Globals</key>
	<array>
		<dict>
			<key>label</key>
			<string>API URL</string>
			<key>name</key>
			<string>apiURL</string>
			<key>type</key>
			<string>string</string>
			<key>default</key>
			<string>https://office-manager.codish.de/api.php</string>
			<key>placeholder</key>
			<string>https://ihre-domain.de/api.php</string>
		</dict>
		<dict>
			<key>label</key>
			<string>API Key</string>
			<key>name</key>
			<string>apiKey</string>
			<key>type</key>
			<string>password</string>
		</dict>
		<dict>
			<key>label</key>
			<string>API Secret</string>
			<key>name</key>
			<string>apiSecret</string>
			<key>type</key>
			<string>password</string>
		</dict>
		<dict>
			<key>label</key>
			<string>Nur nicht abgerechnete Eintraege laden</string>
